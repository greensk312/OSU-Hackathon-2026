{
  "manifest_version": 3,
  "name": "Canvas++",
  "version": "0.2.1",
  "description": "An AI powered study assistant built right into Canvas",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "study-material/flashcards.html",
        "study-material/flashcards.css",
        "study-material/flashcards.js",
        "study-material/quiz.html",
        "study-material/quiz.css",
        "study-material/quiz.js"
        
      ],
      "matches": ["https://*.instructure.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instructure.com/*"
      ],
      "js": [
        "level-system/xp-calculator.js",
        "level-system/level-box.js",
        "study-material/course-buttons.js",
        "study-material/course-home-buttons.js",
        "canvas-data-fetcher.js",
        "content.js"
      ]
    }
  ]
}