{
  "manifest_version": 3,
  "name": "Canvas Multitool",
  "version": "0.1.0",
  "description": "A student-built multitool for Canvas LMS",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.instructure.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
