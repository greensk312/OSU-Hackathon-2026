{
  "manifest_version": 3,
  "name": "Canvas Study Tool",
  "version": "1.0",
  "description": "AI-powered study tool for Canvas",
  "permissions": ["storage"],
  "host_permissions": [
    "https://canvas.instructure.com/*",
    "https://*.instructure.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}